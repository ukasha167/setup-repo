// ~/.config/zed/settings.json
{
    // ─── CORE / META ────────────────────────────────────────────────────────────
    "auto_update": false,
    "base_keymap": "VSCode",
    "icon_theme": "Material Icon Theme",
    // ─── THEME ──────────────────────────────────────────────────────────────────
    "theme": {
        "mode": "dark",
        "light": "One Light",
        "dark": "macOS Classic Dark"
    },
    // ─── TYPOGRAPHY ─────────────────────────────────────────────────────────────
    "ui_font_size": 16,
    "buffer_font_size": 15,
    "buffer_font_family": ".ZedMono", // change to your font if different
    "buffer_font_features": {
        "calt": true // ligatures — set false if you dislike them
    },
    "buffer_line_height": "comfortable",
    // ─── EDITOR BEHAVIOR ────────────────────────────────────────────────────────
    "cursor_shape": "block",
    "cursor_blink": false,
    "current_line_highlight": "none",
    "soft_wrap": "none",
    "show_whitespaces": "none",
    "linked_edits": true,
    "use_autoclose": true,
    "use_auto_surround": true,
    "colorize_brackets": true,
    "use_smartcase_search": true,
    "selection_highlight": true,
    "preferred_line_length": 80,
    "scroll_beyond_last_line": "vertical_scroll_margin",
    "vertical_scroll_margin": 8,
    "horizontal_scroll_margin": 5,
    "tab_size": 4,
    "hard_tabs": false,
    // ─── SAVE BEHAVIOR ──────────────────────────────────────────────────────────
    "format_on_save": "on",
    "formatter": "language_server",
    "remove_trailing_whitespace_on_save": true,
    "ensure_final_newline_on_save": false,
    // ─── AI / PREDICTIONS ───────────────────────────────────────────────────────
    "show_edit_predictions": true,
    "edit_predictions": {
        "provider": "zed",
        "disabled_globs": [
            "**/.env*",
            "**/*.pem",
            "**/*.key",
            "**/*.cert",
            "**/*.crt",
            "**/.dev.vars",
            "**/secrets.yml"
        ]
    },
    // ─── MINIMAP ────────────────────────────────────────────────────────────────
    "minimap": {
        "show": "never"
    },
    // ─── SCROLLBAR ──────────────────────────────────────────────────────────────
    "scrollbar": {
        "show": "auto",
        "git_diff": true,
        "search_results": true,
        "selected_symbol": true,
        "selected_text": true,
        "diagnostics": "all",
        "axes": {
            "horizontal": true,
            "vertical": true
        }
    },
    // ─── GUTTER ─────────────────────────────────────────────────────────────────
    "gutter": {
        "line_numbers": true,
        "runnables": true,
        "breakpoints": true,
        "folds": true,
        "min_line_number_digits": 4
    },
    "relative_line_numbers": "enabled",
    // ─── TOOLBAR ────────────────────────────────────────────────────────────────
    "toolbar": {
        "breadcrumbs": false,
        "quick_actions": false,
        "selections_menu": true,
        "agent_review": true
    },
    // ─── STATUS BAR ─────────────────────────────────────────────────────────────
    "status_bar": {
        "experimental.show": false
    },
    // ─── TABS ───────────────────────────────────────────────────────────────────
    "tabs": {
        "file_icons": true,
        "git_status": true,
        "show_diagnostics": "all",
        "close_position": "right",
        "activate_on_close": "history",
        "show_close_button": "hover"
    },
    "tab_bar": {
        "show": true,
        "show_nav_history_buttons": true
    },
    "preview_tabs": {
        "enabled": true,
        "enable_preview_from_project_panel": true,
        "enable_preview_from_file_finder": false
    },
    // ─── INDENT GUIDES ──────────────────────────────────────────────────────────
    "indent_guides": {
        "enabled": true,
        "line_width": 1,
        "active_line_width": 2
    },
    // ─── GIT ────────────────────────────────────────────────────────────────────
    "git": {
        "git_gutter": "tracked_files",
        "hunk_style": "staged_hollow",
        "inline_blame": {
            "enabled": false
        },
        "branch_picker": {
            "show_author_name": true
        }
    },
    // ─── DIAGNOSTICS ────────────────────────────────────────────────────────────
    "diagnostics": {
        "include_warnings": true,
        "inline": {
            "enabled": true,
            "update_debounce_ms": 150,
            "max_severity": "error"
        }
    },
    // ─── INLAY HINTS ────────────────────────────────────────────────────────────
    "inlay_hints": {
        "enabled": true,
        "show_type_hints": true,
        "show_parameter_hints": true,
        "show_other_hints": true,
        "show_background": false,
        "edit_debounce_ms": 700,
        "scroll_debounce_ms": 50
    },
    // ─── LSP ────────────────────────────────────────────────────────────────────
    "lsp_highlight_debounce": 75,
    "hover_popover_enabled": true,
    "hover_popover_delay": 350,
    "auto_signature_help": true,
    "global_lsp_settings": {
        "button": true,
        "request_timeout": 120,
        "notifications": {
            "dismiss_timeout_ms": 4000
        }
    },
    // ─── SEARCH ─────────────────────────────────────────────────────────────────
    "search": {
        "whole_word": false,
        "case_sensitive": false,
        "regex": false,
        "include_ignored": false,
        "center_on_match": true
    },
    "seed_search_query_from_cursor": "always",
    // ─── PROJECT PANEL ──────────────────────────────────────────────────────────
    "project_panel": {
        "dock": "left",
        "default_width": 240,
        "git_status": true,
        "file_icons": true,
        "folder_icons": true,
        "auto_reveal_entries": true,
        "auto_fold_dirs": true,
        "bold_folder_labels": false,
        "indent_size": 18,
        "sort_mode": "directories_first",
        "sticky_scroll": true,
        "indent_guides": {
            "show": "always"
        }
    },
    // ─── TERMINAL ───────────────────────────────────────────────────────────────
    "terminal": {
        "dock": "bottom",
        "shell": "system",
        "working_directory": "current_project_directory",
        "font_family": "JetBrains Mono",
        "font_size": 13.5,
        "line_height": "standard",
        "blinking": "terminal_controlled",
        "copy_on_select": false,
        "keep_selection_on_copy": true,
        "option_as_meta": false,
        "scroll_multiplier": 3.0,
        "minimum_contrast": 45,
        "toolbar": {
            "breadcrumbs": false
        },
        "detect_venv": {
            "on": {
                "directories": [
                    ".env",
                    "env",
                    ".venv",
                    "venv"
                ],
                "activate_script": "default"
            }
        }
    },
    "middle_click_paste": false,
    // ─── SESSION ────────────────────────────────────────────────────────────────
    "session": {
        "restore_unsaved_buffers": true,
        "trust_all_worktrees": true
    },
    "restore_on_startup": "last_session",
    // ─── TELEMETRY ──────────────────────────────────────────────────────────────
    "telemetry": {
        "diagnostics": false,
        "metrics": false
    },
    // ─── FILE SCAN EXCLUSIONS ───────────────────────────────────────────────────
    // Not indexed, not searched, not shown in file tree — direct perf impact
    "file_scan_exclusions": [
        "**/.git",
        "**/.svn",
        "**/.hg",
        "**/.jj",
        "**/CVS",
        "**/.DS_Store",
        "**/Thumbs.db",
        "**/.classpath",
        "**/.settings",
        "**/node_modules",
        "**/dist",
        "**/build",
        "**/.next",
        "**/.nuxt",
        "**/target",
        "**/.gradle",
        "**/android/.gradle",
        "**/android/build",
        "**/android/app/build",
        "**/.dart_tool",
        "**/.flutter-plugins",
        "**/.flutter-plugins-dependencies",
        "**/ios/Pods",
        "**/ios/.symlinks",
        "**/linux/flutter",
        "**/windows/flutter",
        "**/__pycache__",
        "**/*.pyc",
        "**/.mypy_cache",
        "**/.pytest_cache",
        "**/CMakeFiles",
        "**/*.o",
        "**/*.a",
        "**/.idea",
        "**/coverage"
    ],
    // ─── LANGUAGE OVERRIDES ─────────────────────────────────────────────────────
    "languages": {
        "Dart": {
            "tab_size": 2,
            "format_on_save": "on",
            "formatter": "language_server",
            "remove_trailing_whitespace_on_save": true,
            "indent_guides": {
                "enabled": true
            }
        },
        "JavaScript": {
            "tab_size": 2,
            "format_on_save": "on",
            "formatter": "language_server"
        },
        "TypeScript": {
            "tab_size": 2,
            "format_on_save": "on",
            "formatter": "language_server",
            "document_symbols": "on",
            "semantic_tokens": "combined"
        },
        "TSX": {
            "tab_size": 2,
            "format_on_save": "on"
        },
        "HTML": {
            "tab_size": 2,
            "format_on_save": "on"
        },
        "CSS": {
            "tab_size": 2,
            "format_on_save": "on"
        },
        "JSON": {
            "tab_size": 2,
            "format_on_save": "on"
        },
        "Python": {
            "tab_size": 4,
            "format_on_save": "on",
            "formatter": "language_server",
            "indent_guides": {
                "enabled": true
            }
        },
        "Java": {
            "tab_size": 4,
            "format_on_save": "on",
            "formatter": "language_server",
            "semantic_tokens": "combined"
        },
        "Kotlin": {
            "tab_size": 4,
            "format_on_save": "on",
            "formatter": "language_server"
        },
        "C": {
            "tab_size": 4,
            "format_on_save": "on",
            "formatter": "language_server",
            "preferred_line_length": 80,
            "soft_wrap": "preferred_line_length"
        },
        "C++": {
            "tab_size": 4,
            "format_on_save": "on",
            "formatter": "language_server",
            "preferred_line_length": 80
        },
        "SQL": {
            "tab_size": 2,
            "format_on_save": "off"
        },
        "Markdown": {
            "soft_wrap": "preferred_line_length",
            "preferred_line_length": 80,
            "format_on_save": "off",
            "show_edit_predictions": false
        },
        "YAML": {
            "tab_size": 2,
            "format_on_save": "on"
        }
    }
}
